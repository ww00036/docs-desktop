{
  "name": "mipmap-docs-desktop",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "MipMap",
  "homepage": "https://docs.mipmap3d.com/desktop/",
  "repository": {
    "type": "git",
    "url": "https://github.com/MipMap-Software/docs-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/MipMap-Software/docs-desktop/issues"
  },
  "scripts": {
    "dev": "vitepress dev docs --host 0.0.0.0 --port 4002",
    "build": "vitepress build docs",
    "serve": "vitepress preview docs --port 4002",
    "export:pdf": "node scripts/export-pdf.mjs",
    "export:pdf:en": "node scripts/export-pdf.mjs --lang=en",
    "export:pdf:zh": "node scripts/export-pdf.mjs --lang=zh-Hans",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "markdown-it-image-figures": "^2.1.1",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18.0"
  },
  "packageManager": "yarn@1.22.22"
}
